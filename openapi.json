{
  "openapi": "3.0.0",
  "info": {
    "title": "Cloudflare Storage Service",
    "version": "1.0.0",
    "description": "Stores and serves files on Cloudflare R2"
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Api-Key"
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          },
          "service": {
            "type": "string",
            "example": "cloudflare-storage-service"
          }
        },
        "required": [
          "status",
          "service"
        ]
      },
      "UploadResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "File record UUID"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Permanent public URL"
          },
          "size": {
            "type": "integer",
            "description": "File size in bytes"
          },
          "contentType": {
            "type": "string",
            "description": "MIME type"
          }
        },
        "required": [
          "id",
          "url",
          "size",
          "contentType"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        },
        "required": [
          "error"
        ]
      },
      "UploadRequest": {
        "type": "object",
        "properties": {
          "sourceUrl": {
            "type": "string",
            "format": "uri",
            "description": "URL to download the file from"
          },
          "folder": {
            "type": "string",
            "description": "R2 key prefix/folder"
          },
          "filename": {
            "type": "string",
            "description": "Desired filename"
          },
          "contentType": {
            "type": "string",
            "description": "MIME type"
          }
        },
        "required": [
          "sourceUrl"
        ]
      },
      "FileResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "folder": {
            "type": "string",
            "nullable": true
          },
          "filename": {
            "type": "string"
          },
          "contentType": {
            "type": "string",
            "nullable": true
          },
          "size": {
            "type": "integer",
            "nullable": true
          },
          "orgId": {
            "type": "string",
            "format": "uuid"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "url",
          "folder",
          "filename",
          "contentType",
          "size",
          "orgId",
          "createdAt"
        ]
      },
      "TransferBrandResponse": {
        "type": "object",
        "properties": {
          "updatedTables": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "tableName": {
                  "type": "string"
                },
                "count": {
                  "type": "integer"
                }
              },
              "required": [
                "tableName",
                "count"
              ]
            }
          }
        },
        "required": [
          "updatedTables"
        ]
      },
      "TransferBrandRequest": {
        "type": "object",
        "properties": {
          "brandId": {
            "type": "string",
            "format": "uuid",
            "description": "Brand UUID to transfer"
          },
          "sourceOrgId": {
            "type": "string",
            "format": "uuid",
            "description": "Current org UUID"
          },
          "targetOrgId": {
            "type": "string",
            "format": "uuid",
            "description": "Destination org UUID"
          }
        },
        "required": [
          "brandId",
          "sourceOrgId",
          "targetOrgId"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/upload": {
      "post": {
        "summary": "Upload a file to R2",
        "description": "Downloads a file from a given URL and uploads it to Cloudflare R2",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Internal org UUID"
            },
            "required": true,
            "name": "x-org-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Internal user UUID"
            },
            "required": true,
            "name": "x-user-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Run ID from runs-service"
            },
            "required": true,
            "name": "x-run-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Comma-separated list of brand UUIDs (e.g. uuid1,uuid2,uuid3)",
              "example": "00000000-0000-0000-0000-000000000001,00000000-0000-0000-0000-000000000002"
            },
            "required": false,
            "name": "x-brand-id",
            "in": "header"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UploadRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File uploaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Upload failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/files/{id}": {
      "get": {
        "summary": "Get file metadata",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "id",
            "in": "path"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Internal org UUID"
            },
            "required": true,
            "name": "x-org-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Internal user UUID"
            },
            "required": true,
            "name": "x-user-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Run ID from runs-service"
            },
            "required": true,
            "name": "x-run-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Comma-separated list of brand UUIDs (e.g. uuid1,uuid2,uuid3)",
              "example": "00000000-0000-0000-0000-000000000001,00000000-0000-0000-0000-000000000002"
            },
            "required": false,
            "name": "x-brand-id",
            "in": "header"
          }
        ],
        "responses": {
          "200": {
            "description": "File metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileResponse"
                }
              }
            }
          },
          "404": {
            "description": "File not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete a file",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "id",
            "in": "path"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Internal org UUID"
            },
            "required": true,
            "name": "x-org-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Internal user UUID"
            },
            "required": true,
            "name": "x-user-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Run ID from runs-service"
            },
            "required": true,
            "name": "x-run-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Comma-separated list of brand UUIDs (e.g. uuid1,uuid2,uuid3)",
              "example": "00000000-0000-0000-0000-000000000001,00000000-0000-0000-0000-000000000002"
            },
            "required": false,
            "name": "x-brand-id",
            "in": "header"
          }
        ],
        "responses": {
          "204": {
            "description": "File deleted successfully"
          },
          "404": {
            "description": "File not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/images/{key}": {
      "get": {
        "summary": "Serve an image from R2 with optional resizing",
        "description": "Fetches an image from R2 by key. Supports on-the-fly resizing via query params: w (width), h (height), fit (cover|contain|fill|inside|outside), format (webp|avif|png|jpeg), quality (1-100).",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "description": "R2 object key (full path)"
            },
            "required": true,
            "name": "key",
            "in": "path"
          },
          {
            "schema": {
              "type": "string",
              "description": "Max width in pixels (1-4096)"
            },
            "required": false,
            "name": "w",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "description": "Max height in pixels (1-4096)"
            },
            "required": false,
            "name": "h",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "enum": [
                "cover",
                "contain",
                "fill",
                "inside",
                "outside"
              ],
              "description": "Resize fit mode"
            },
            "required": false,
            "name": "fit",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "enum": [
                "webp",
                "avif",
                "png",
                "jpeg"
              ],
              "description": "Output format"
            },
            "required": false,
            "name": "format",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "description": "Output quality (1-100)"
            },
            "required": false,
            "name": "quality",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Internal org UUID"
            },
            "required": true,
            "name": "x-org-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Internal user UUID"
            },
            "required": true,
            "name": "x-user-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Run ID from runs-service"
            },
            "required": true,
            "name": "x-run-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Comma-separated list of brand UUIDs (e.g. uuid1,uuid2,uuid3)",
              "example": "00000000-0000-0000-0000-000000000001,00000000-0000-0000-0000-000000000002"
            },
            "required": false,
            "name": "x-brand-id",
            "in": "header"
          }
        ],
        "responses": {
          "200": {
            "description": "Image binary",
            "content": {
              "image/*": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "description": "Image not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Image processing failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/internal/transfer-brand": {
      "post": {
        "summary": "Transfer brand ownership between orgs",
        "description": "Re-assigns all solo-brand file rows from sourceOrgId to targetOrgId. Skips co-branding rows.",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TransferBrandRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transfer completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransferBrandResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  }
}